---
interface Props {
  intent: string;
  eyebrow: string;
  title: string;
  titleAccent: string;
  body: string;
  source: string;
}

const { intent, eyebrow, title, titleAccent, body, source } = Astro.props;
---

<div class="intake-layout">
  <div class="intake-copy">
    <p class="cinema-kicker">{eyebrow}</p>
    <h2>
      {title}
      <span>{titleAccent}</span>
    </h2>
    <p>{body}</p>
    <p class="intake-fallback">
      Prefer email? Use <a href={`mailto:info@appliedai.solutions?subject=${encodeURIComponent(intent)}`}>info@appliedai.solutions</a>.
    </p>
  </div>

  <form class="intake-form" method="post" action="/api/intake" data-intake-form>
    <input type="hidden" name="intent" value={intent} />
    <input type="hidden" name="source" value={source} />
    <div class="intake-field intake-honey" aria-hidden="true">
      <label for={`${source}-website`}>Website</label>
      <input id={`${source}-website`} name="website" tabindex="-1" autocomplete="off" />
    </div>
    <div class="intake-field">
      <label for={`${source}-name`}>Name</label>
      <input id={`${source}-name`} name="name" autocomplete="name" required />
    </div>
    <div class="intake-field">
      <label for={`${source}-email`}>Email</label>
      <input id={`${source}-email`} name="email" type="email" autocomplete="email" required />
    </div>
    <div class="intake-field">
      <label for={`${source}-company`}>Company</label>
      <input id={`${source}-company`} name="company" autocomplete="organization" />
    </div>
    <div class="intake-field">
      <label for={`${source}-message`}>What should we look at first?</label>
      <textarea id={`${source}-message`} name="message" rows="5" required></textarea>
    </div>
    <button class="button primary intake-submit" type="submit">Send secure intake</button>
    <p class="intake-status" data-intake-status role="status" aria-live="polite">
      Submissions are captured directly by Applied AI Solutions.
    </p>
  </form>
</div>

<script>
  const forms = document.querySelectorAll("[data-intake-form]");

  forms.forEach((form) => {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const target = event.currentTarget;
      if (!(target instanceof HTMLFormElement)) return;

      const status = target.querySelector("[data-intake-status]");
      const submit = target.querySelector("button[type='submit']");
      if (submit instanceof HTMLButtonElement) submit.disabled = true;
      if (status) status.textContent = "Sending...";

      try {
        const response = await fetch(target.action, {
          method: "POST",
          body: new FormData(target),
          headers: { Accept: "application/json" },
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || !payload.ok) {
          throw new Error(payload.error || "The intake endpoint did not accept the submission.");
        }
        target.reset();
        if (status) status.textContent = "Got it. We captured your note and will follow up from info@appliedai.solutions.";
      } catch (error) {
        if (status) status.textContent = "That did not go through. Email info@appliedai.solutions directly and mention the site form.";
      } finally {
        if (submit instanceof HTMLButtonElement) submit.disabled = false;
      }
    });
  });
</script>
