---
import "../styles/global.css";
import IntakeForm from "../components/IntakeForm.astro";

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Applied AI Solutions project proof: Beacon Voice, Beacon Desk, LightHouseOS, ARC, OpenClaw workflows, HTML handoffs, and approval-safe automation patterns."
    />
    <meta name="theme-color" content="#02050a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260530" />
    <link rel="alternate icon" href="/favicon.ico?v=20260530" />
    <title>Projects | Applied AI Solutions</title>
  </head>
  <body class="cinema-page cinema-page-projects">
    <header class="site-header">
      <nav class="nav shell" aria-label="Projects navigation">
        <a class="brand" href="/">
          <img src="/assets/logo-system/aas-mountain-aa-v4-summit-mark.svg" alt="Applied AI Solutions" width="512" height="512" />
          <span>
            <strong>Applied AI</strong>
            <small>Projects</small>
          </span>
        </a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/beacon/">Beacon</a>
          <a href="#proof">Proof</a>
          <a href="/#services">Services</a>
          <a class="nav-cta" href="#contact">Contact</a>
        </div>
      </nav>
    </header>

    <main class="cinema-main">
      <div class="cinema-stage" aria-hidden="true">
        <canvas class="cinema-webgl" data-cinema-scene></canvas>
        <img class="stage-image stage-image-roots" src="/assets/retrowave/retrowave-system-banner.jpg" alt="" width="1500" height="500" />
        <img class="stage-image stage-image-system" src="/assets/retrowave/beacon-retrowave-banner.jpg" alt="" width="1500" height="500" />
        <img class="stage-image stage-image-mark" src="/assets/retrowave/lighthouseos-retrowave-mark.png" alt="" width="1024" height="1024" />
        <div class="ridge-map">
          <i></i>
          <i></i>
          <i></i>
        </div>
        <div class="stage-readout" aria-hidden="true">
          <span>proof signal</span>
          <strong data-scene-state>route</strong>
        </div>
        <div class="stage-grid"></div>
        <div class="stage-scan"></div>
      </div>

      <nav class="chapter-rail" aria-label="Page chapters">
        <a href="#top">00</a>
        <a href="#proof">01</a>
        <a href="#lanes">02</a>
        <a href="#method">03</a>
        <a href="#contact">04</a>
      </nav>

      <section id="top" class="cinema-hero cinema-panel" data-stage="system">
        <div class="shell cinema-copy hero-copy">
          <p class="cinema-kicker">Build proof / Product lanes / Client patterns</p>
          <h1>
            Working systems,
            <span>not slideware.</span>
          </h1>
          <p class="cinema-lead">
            Applied AI Solutions is built around artifacts: companion surfaces,
            workflow tools, approval gates, durable memory, and handoffs that can
            be opened, inspected, and reused.
          </p>
          <div class="origin-caption" aria-label="Project proof">
            <span>Proof lane</span>
            <strong>Named, bounded, inspectable, and shipped</strong>
          </div>
          <a class="scroll-cue" href="#proof">View the lanes</a>
        </div>
      </section>

      <section id="proof" class="cinema-panel cinema-chapter" data-stage="system">
        <div class="shell cinema-chapter-grid">
          <div class="chapter-meta">
            <span>//01 Proof</span>
            <a href="#top">Back to top</a>
          </div>
          <div class="cinema-copy chapter-copy">
            <h2>
              The model is not
              <span>the deliverable.</span>
            </h2>
            <p>
              The deliverable is the workflow you can trust: a clear surface, a visible
              boundary, a remembered context, an approval path, and a way to inspect what
              happened after the system acts.
            </p>
            <div class="system-phrases" aria-label="Project operating loop">
              <span data-verb="observe">Observe</span>
              <span data-verb="shape">Shape</span>
              <span data-verb="build">Build</span>
              <span data-verb="verify">Verify</span>
              <span data-verb="govern">Govern</span>
            </div>
          </div>
        </div>
      </section>

      <section id="lanes" class="cinema-panel cinema-chapter" data-stage="beacon">
        <div class="shell cinema-chapter-grid">
          <div class="chapter-meta">
            <span>//02 Lanes</span>
            <a href="/beacon/">Explore Beacon</a>
          </div>
          <div class="cinema-copy chapter-copy">
            <h2>
              Each lane becomes
              <span>a reusable pattern.</span>
            </h2>
            <p>
              Beacon proves the companion layer. LightHouseOS proves the local-first
              operating layer. ARC proves the teammate pattern. OpenClaw workflows prove
              that tools, memory, channels, and approval rules can become client systems.
            </p>
            <div class="cinema-name-stack surface-stack" aria-label="Applied AI project lanes">
              <a href="/beacon/"><strong>Beacon</strong><span>voice, desk, companion identity</span></a>
              <a href="#lanes"><strong>LightHouseOS</strong><span>local-first agent layer</span></a>
              <a href="#lanes"><strong>ARC</strong><span>implementation and verification</span></a>
              <a href="#lanes"><strong>OpenClaw workflows</strong><span>tools, memory, approvals</span></a>
            </div>
          </div>
        </div>
      </section>

      <section id="method" class="cinema-panel cinema-chapter" data-stage="roots">
        <div class="shell cinema-chapter-grid">
          <div class="chapter-meta">
            <span>//03 Method</span>
            <a href="/#services">Services</a>
          </div>
          <div class="cinema-copy chapter-copy">
            <h2>
              Start where the
              <span>work leaks time.</span>
            </h2>
            <p>
              We observe the workflow, ship the smallest useful surface, then make
              it explain itself. That means less theater and more systems people can
              use repeatedly without losing control.
            </p>
            <div class="cinema-step-line" aria-label="Applied AI build method">
              <span><strong>Observe</strong> Repetitive work and missing context</span>
              <span><strong>Build</strong> A useful tool, report, or companion surface</span>
              <span><strong>Govern</strong> Memory, actions, approvals, and outputs</span>
            </div>
          </div>
        </div>
      </section>

      <section id="contact" class="cinema-panel cinema-chapter cinema-final" data-stage="mark">
        <div class="shell cinema-copy final-copy">
          <IntakeForm
            eyebrow="//04 Build"
            title="Show us the workflow."
            titleAccent="We shape the system."
            body="Intake, documents, reports, scheduling, approvals, training, follow-up, or the internal process that everyone knows needs a better operating layer."
            intent="Applied AI Project Inquiry"
            source="projects"
          />
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="shell footer-inner">
        <span>© {year} Applied AI Solutions</span>
        <nav aria-label="Footer navigation">
          <a href="/">Applied AI Solutions</a>
          <a href="/beacon/">Beacon</a>
          <a href="https://github.com/Applied-AI-Solutions-hub/aas">GitHub</a>
          <a href="mailto:info@appliedai.solutions">info@appliedai.solutions</a>
        </nav>
      </div>
    </footer>
    <script>
      import "../scripts/site-motion.js";
    </script>
  </body>
</html>
