---
import "../styles/global.css";

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Applied AI Solutions project proof: Beacon Voice, Beacon Desk, LightHouseOS, ARC, OpenClaw workflows, HTML handoffs, and approval-safe automation patterns."
    />
    <meta name="theme-color" content="#02050a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260530" />
    <link rel="alternate icon" href="/favicon.ico?v=20260530" />
    <title>Projects | Applied AI Solutions</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav shell" aria-label="Projects navigation">
        <a class="brand" href="/">
          <img src="/assets/logo-system/aas-mountain-aa-v4-summit-mark.svg" alt="Applied AI Solutions" width="512" height="512" />
          <span>
            <strong>Applied AI</strong>
            <small>Projects</small>
          </span>
        </a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/beacon/">Beacon</a>
          <a href="#proof">Proof</a>
          <a href="/#services">Services</a>
          <a class="nav-cta" href="mailto:info@appliedai.solutions?subject=Applied%20AI%20Project%20Inquiry">Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <section class="hero hero-projects">
        <div class="hero-art" aria-hidden="true">
          <img src="/assets/retrowave/retrowave-system-banner.jpg" alt="" width="1500" height="500" />
          <div class="motion-field">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
        <div class="shell hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">Build proof</p>
            <h1>Working systems, named clearly and built in public enough to trust.</h1>
            <p class="lead">
              Applied AI Solutions is built around artifacts: companion surfaces, workflow tools,
              approval gates, durable memory, and handoffs that can be opened, inspected, and reused.
            </p>
            <div class="action-row">
              <a class="button primary" href="#proof">View proof lanes</a>
              <a class="button secondary" href="/beacon/">Explore Beacon</a>
            </div>
            <a class="scroll-cue" href="#proof">Scroll to discover more</a>
          </div>
          <aside class="system-panel">
            <div class="panel-header">
              <span class="status-dot"></span>
              <strong>Build lanes</strong>
            </div>
            <div class="metric-grid">
              <div><strong>Beacon</strong><span>companion product</span></div>
              <div><strong>LightHouseOS</strong><span>local-first layer</span></div>
              <div><strong>ARC</strong><span>agent teammate</span></div>
              <div><strong>OpenClaw</strong><span>runtime backbone</span></div>
            </div>
          </aside>
        </div>
      </section>

      <section class="route-dock" aria-label="Project routes">
        <div class="shell route-grid route-grid-three">
          <a class="route-card" href="/">
            <span>AAS</span>
            <strong>Consulting Home</strong>
            <small>Strategy, implementation, training, and governed automation.</small>
          </a>
          <a class="route-card" href="/beacon/">
            <span>Beacon</span>
            <strong>Companion System</strong>
            <small>Voice, Desk, and the front door to LightHouseOS.</small>
          </a>
          <a class="route-card featured-route" href="#proof">
            <span>Proof</span>
            <strong>Build Lanes</strong>
            <small>Reusable patterns for client workflow systems.</small>
          </a>
        </div>
      </section>

      <section id="proof" class="section">
        <div class="shell">
          <div class="section-copy-block section-lead">
            <p class="eyebrow">Featured lanes</p>
            <h2>Each lane is a reusable pattern for client work.</h2>
            <p>
              The point is not to show off a model. The point is to prove that AI work can be
              named, bounded, inspected, and shipped.
            </p>
          </div>

          <div class="case-grid">
            <article class="case-card case-card-featured">
              <img src="/assets/retrowave/beacon-retrowave-banner.jpg" alt="" width="1500" height="500" />
              <div>
                <span>Product lab</span>
                <h3>Beacon</h3>
                <p>Beacon Voice, Beacon Desk, and the companion identity around LightHouseOS.</p>
                <ul>
                  <li>Voice collaboration with routed tool work</li>
                  <li>Desktop companion shell path</li>
                  <li>Consistent product and marketing language</li>
                </ul>
                <a href="/beacon/">View Beacon</a>
              </div>
            </article>

            <article class="case-card">
              <img class="case-mark case-mark-current" src="/assets/retrowave/lighthouseos-retrowave-mark.png" alt="LightHouseOS retrowave mark" width="1024" height="1024" />
              <span>Platform direction</span>
              <h3>LightHouseOS</h3>
              <p>The local-first operating layer for agents, durable goals, memory, tools, voice, and approval routing.</p>
              <ul>
                <li>Local secure AGI direction</li>
                <li>Human approval boundaries</li>
                <li>Future workstation packaging</li>
              </ul>
            </article>

            <article class="case-card">
              <img class="case-mark case-mark-current" src="/assets/retrowave/aas-retrowave-mark.png" alt="Applied AI Solutions retrowave mark" width="1024" height="1024" />
              <span>Agent teammate</span>
              <h3>ARC</h3>
              <p>The Applied Responsive Companion for implementation, verification, durable memory, and workflow design.</p>
              <ul>
                <li>Workspace operating rules</li>
                <li>Skill and tool routing</li>
                <li>Verification before done</li>
              </ul>
            </article>

            <article class="case-card">
              <span>Runtime backbone</span>
              <h3>OpenClaw workflows</h3>
              <p>Local tools, skills, cron, channels, memory, and approval rules turned into reusable business workflows.</p>
              <ul>
                <li>Discord and voice lanes</li>
                <li>Microsoft 365 read-only checks</li>
                <li>Approval-gated external actions</li>
              </ul>
            </article>

            <article class="case-card">
              <span>Client delivery</span>
              <h3>HTML handoffs</h3>
              <p>Portable reports and previews that work away from home, without requiring localhost or a live agent session.</p>
              <ul>
                <li>Self-contained review packets</li>
                <li>Mobile-readable previews</li>
                <li>Clear final action scope</li>
              </ul>
            </article>

            <article class="case-card">
              <span>Services</span>
              <h3>AI workflow systems</h3>
              <p>Strategy and implementation for inboxes, documents, reports, intake, approvals, training, and follow-up.</p>
              <ul>
                <li>Workflow discovery</li>
                <li>Private knowledge systems</li>
                <li>Automation with approvals</li>
              </ul>
            </article>
          </div>
        </div>
      </section>

      <section class="section section-contrast">
        <div class="shell proof-band">
          <div>
            <p class="eyebrow">How we build</p>
            <h2>Observe the workflow, ship the smallest useful surface, then make it explain itself.</h2>
          </div>
          <div class="proof-list">
            <article>
              <strong>Observe</strong>
              <p>Find the repetitive work, missing context, handoff gaps, and decision points.</p>
            </article>
            <article>
              <strong>Build</strong>
              <p>Create a tool, report, automation, or companion surface that proves the workflow.</p>
            </article>
            <article>
              <strong>Govern</strong>
              <p>Expose memory, actions, approvals, and outputs so the system can be trusted.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section final-cta">
        <div class="shell cta-band">
          <div>
            <p class="eyebrow">Build with us</p>
            <h2>Show us the workflow. We will shape the system.</h2>
          </div>
          <a class="button primary" href="mailto:info@appliedai.solutions?subject=Applied%20AI%20Project%20Inquiry">Start a project conversation</a>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="shell footer-inner">
        <span>© {year} Applied AI Solutions</span>
        <nav aria-label="Footer navigation">
          <a href="/">Applied AI Solutions</a>
          <a href="/beacon/">Beacon</a>
          <a href="mailto:info@appliedai.solutions">info@appliedai.solutions</a>
        </nav>
      </div>
    </footer>
    <script>
      import "../scripts/site-motion.js";
    </script>
  </body>
</html>
