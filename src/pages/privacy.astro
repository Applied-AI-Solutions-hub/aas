---
import "../styles/global.css";
const updated = "June 13, 2026";
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Applied AI Solutions privacy policy — what we collect, how we use it, and your choices." />
    <meta name="theme-color" content="#02050a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260530" />
    <link rel="alternate icon" href="/favicon.ico?v=20260530" />
    <title>Privacy Policy | Applied AI Solutions</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav shell" aria-label="Main navigation">
        <a class="brand" href="/">
          <img src="/assets/logo-system/aas-mountain-aa-v4-summit-mark.svg" alt="Applied AI Solutions" width="512" height="512" />
          <span><strong>Applied AI</strong><small>Solutions</small></span>
        </a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/beacon/">Beacon</a>
          <a href="/projects/">Projects</a>
          <a class="nav-cta" href="/#contact">Contact</a>
        </div>
      </nav>
    </header>

    <main class="legal">
      <div class="shell">
        <h1>Privacy Policy</h1>
        <p class="upd">Last updated: {updated}</p>

        <p>Applied AI Solutions ("we," "us") builds local-first AI systems. This policy
          explains what information we collect through this website
          (appliedai.solutions) and how we use it. We keep this short and plain on
          purpose — privacy is the point of what we build.</p>

        <h2>What we collect</h2>
        <ul>
          <li><strong>Information you send us.</strong> When you use a contact or intake
            form, we collect what you submit — typically your name, email, company, and
            your message.</li>
          <li><strong>Basic technical data.</strong> Standard server and security logs
            (e.g., IP address, request time) that our hosting provider records to keep
            the site running and secure.</li>
          <li>We do not run advertising trackers, and we do not build profiles on you.</li>
        </ul>

        <h2>How we use it</h2>
        <ul>
          <li>To respond to your inquiry and provide the services you ask about.</li>
          <li>To operate, secure, and improve the website.</li>
          <li>We do <strong>not</strong> sell, rent, or trade your personal information.</li>
        </ul>

        <h2>Where it's stored &amp; who processes it</h2>
        <p>The site and form submissions are hosted on Cloudflare, which stores the data
          on our behalf. If we send ourselves an email notification of a new inquiry, we
          use an email delivery provider (Resend) to do so. These providers act only as
          processors under our instructions.</p>

        <h2>Social media publishing</h2>
        <p>We use official platform APIs (such as LinkedIn) to publish posts to our own
          Applied AI Solutions accounts. This integration posts on our behalf only — it
          does not access, collect, or store data about other people's accounts.</p>

        <h2>Retention</h2>
        <p>We keep inquiry information only as long as needed to respond and to maintain
          our business records, then delete it.</p>

        <h2>Your choices</h2>
        <p>You can ask us what information we hold about you, ask us to correct it, or ask
          us to delete it. Email <a href="mailto:info@appliedai.solutions">info@appliedai.solutions</a>
          and we'll take care of it.</p>

        <h2>Children</h2>
        <p>This site is not directed to children under 13, and we don't knowingly collect
          their information.</p>

        <h2>Changes</h2>
        <p>If we update this policy, we'll change the date above. Material changes will be
          noted on this page.</p>

        <h2>Contact</h2>
        <p>Questions? <a href="mailto:info@appliedai.solutions">info@appliedai.solutions</a></p>
      </div>
      <footer class="shell legal-foot">Applied AI Solutions · {year}</footer>
    </main>

    <style>
      .legal{background:#07040d;color:#e7e9ee;padding:48px 0 64px;
        font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;line-height:1.7}
      .legal .shell{max-width:760px;margin:0 auto;padding:0 22px}
      .legal h1{font-size:38px;font-weight:700;margin:0 0 6px;letter-spacing:-.02em;
        background:linear-gradient(135deg,#36e2ff,#a06bff 55%,#ff2e93);-webkit-background-clip:text;background-clip:text;color:transparent}
      .legal .upd{color:#9aa0b5;font-size:13px;margin:0 0 28px}
      .legal h2{font-size:19px;font-weight:600;color:#fff;margin:30px 0 8px}
      .legal p,.legal li{font-size:15.5px;color:#c8ccd8}
      .legal ul{padding-left:20px;margin:8px 0}
      .legal li{margin:6px 0}
      .legal a{color:#36e2ff}
      .legal-foot{color:#7c8190;font-size:12.5px;margin-top:40px;border-top:1px solid rgba(255,255,255,.1);padding-top:20px}
    </style>
  </body>
</html>
