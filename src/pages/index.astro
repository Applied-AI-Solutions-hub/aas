---
import "../styles/global.css";

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Applied AI Solutions helps businesses turn AI ideas into practical workflows, private knowledge systems, team training, and approval-safe automation."
    />
    <meta name="theme-color" content="#000000" />
    <title>Applied AI Solutions | Practical AI Systems</title>
  </head>
  <body class="aas-page aas-landing redesigned-page">
    <div class="cosmic-backdrop" aria-hidden="true"></div>

    <header class="site-header aas-site-header">
      <nav class="nav shell" aria-label="Main navigation">
        <a class="brand" href="/">
          <img
            class="brand-header-mark"
            src="/assets/aas-logo-current.jpg"
            alt="Applied AI Solutions"
            width="512"
            height="512"
          />
          <span class="brand-lockup">
            <strong>Applied AI</strong>
            <span>Solutions</span>
          </span>
        </a>
        <div class="nav-links">
          <a href="/projects/">Projects</a>
          <a href="/beacon/">Beacon</a>
          <a href="#services">Services</a>
          <a class="button secondary" href="mailto:info@appliedai.solutions">Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <section class="redesign-hero aas-redesign-hero" aria-labelledby="hero-title">
        <div class="hero-media hero-media-aas" aria-hidden="true">
          <video autoplay muted loop playsinline preload="metadata" poster="/assets/aas-logo-current.jpg">
            <source src="/assets/aas-logo-pulse.mp4" type="video/mp4" />
          </video>
        </div>

        <div class="shell redesign-hero-grid">
          <div class="redesign-hero-copy" data-animate>
            <p class="eyebrow">AI consulting for business operators</p>
            <h1 id="hero-title">Build AI workflows your team can actually run.</h1>
            <p class="lead">
              Applied AI Solutions helps companies move from scattered AI experiments to
              practical systems for intake, documents, knowledge, reporting, training, and
              approval-safe automation.
            </p>
            <div class="hero-actions">
              <a class="button" href="mailto:info@appliedai.solutions?subject=AI%20Workflow%20Consultation">
                Start a strategy call
              </a>
              <a class="button secondary" href="/projects/">View our builds</a>
            </div>
            <p class="hero-note">Move your cursor through the system.</p>
          </div>

          <div class="workflow-stage" data-workflow-stage data-animate aria-label="Interactive Applied AI workflow system">
            <div class="workflow-stage-fallback" aria-hidden="true">
              <img src="/assets/aas-logo-current.jpg" alt="" width="512" height="512" />
              <span>Documents</span>
              <span>Approvals</span>
              <span>Memory</span>
              <span>Reports</span>
            </div>
            <div class="workflow-stage-caption">
              <span class="status-dot"></span>
              <strong>Live workflow system</strong>
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="section redesigned-section">
        <div class="shell split-section">
          <div class="section-header" data-animate>
            <p class="eyebrow">Services</p>
            <h2>Strategy, implementation, and training under one roof.</h2>
            <p class="section-copy">
              We keep the work grounded in business outcomes: less time searching, cleaner
              follow-up, better handoffs, and automation that still leaves important decisions
              reviewable.
            </p>
          </div>
          <div class="service-list" data-animate>
            <article>
              <span>01</span>
              <h3>AI workflow strategy</h3>
              <p>Find the use cases worth building and the areas where AI should stay out.</p>
            </article>
            <article>
              <span>02</span>
              <h3>Private knowledge systems</h3>
              <p>Turn policies, SOPs, documents, and project history into searchable context.</p>
            </article>
            <article>
              <span>03</span>
              <h3>Automation with approvals</h3>
              <p>Connect tools and workflows while keeping external actions visible.</p>
            </article>
            <article>
              <span>04</span>
              <h3>Team enablement</h3>
              <p>Train owners and staff with practical playbooks, review points, and standards.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section redesigned-section proof-section">
        <div class="shell proof-grid" data-animate>
          <div>
            <p class="eyebrow">How we work</p>
            <h2>Built for trust before scale.</h2>
          </div>
          <div class="proof-matrix">
            <article>
              <strong>Human approval boundaries</strong>
              <p>Customer messages, account changes, spending, and publishing stay gated.</p>
            </article>
            <article>
              <strong>Local-first product learning</strong>
              <p>LightHouseOS gives us a real internal lab for memory, goals, tools, voice, and desktop presence.</p>
            </article>
            <article>
              <strong>Professional delivery artifacts</strong>
              <p>Plans, reports, and demos are designed for operators to scan and trust.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section redesigned-section">
        <div class="shell feature-callout" data-animate>
          <div>
            <p class="eyebrow">Product lab</p>
            <h2>LightHouseOS is where our agentic business software becomes real.</h2>
            <p class="section-copy">
              Beacon Voice and Beacon Desk are the companion surfaces. Underneath them, LightHouseOS
              is the local-first layer for memory, goals, approvals, documents, tools, and eventually
              an installable AI workstation environment.
            </p>
          </div>
          <div class="callout-actions">
            <a class="button beacon-nav" href="/beacon/">Explore Beacon</a>
            <a class="button secondary" href="/projects/">See project work</a>
          </div>
        </div>
      </section>

      <section id="contact" class="section redesigned-section contact-band">
        <div class="shell contact-band-inner" data-animate>
          <div>
            <p class="eyebrow">Next step</p>
            <h2>Bring one workflow worth fixing.</h2>
            <p class="section-copy">
              Send the business problem, the tools involved, and what slows the team down. We will
              turn that into a practical first plan.
            </p>
          </div>
          <a class="button" href="mailto:info@appliedai.solutions?subject=AI%20Workflow%20Consultation">
            Email Applied AI Solutions
          </a>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="shell">
        <a class="footer-brand" href="/" aria-label="Applied AI Solutions home">
          <img src="/assets/aas-logo-current.jpg" alt="Applied AI Solutions" width="512" height="512" />
        </a>
        <span>© {year}</span>
        <div class="footer-links">
          <a href="/projects/">Projects</a>
          <a href="/beacon/">Beacon</a>
          <a href="mailto:info@appliedai.solutions">info@appliedai.solutions</a>
        </div>
      </div>
    </footer>

    <script>
      import { animate, inView, stagger } from "motion";
      import { mountWorkflowPhysics } from "../scripts/workflow-physics.js";

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      mountWorkflowPhysics("[data-workflow-stage]");

      if (!reduceMotion) {
        inView("[data-animate]", (element) => {
          animate(
            element,
            { opacity: [0, 1], transform: ["translateY(18px)", "translateY(0)"] },
            { duration: 0.58, delay: stagger(0.035), easing: [0.22, 1, 0.36, 1] }
          );
        }, { margin: "0px 0px -10% 0px" });
      }
    </script>
  </body>
</html>
