---
import "../styles/global.css";
import IntakeForm from "../components/IntakeForm.astro";

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Applied AI Solutions builds local-first AI systems, private workflow memory, approval-aware automation, and companion tools from the roots of real work."
    />
    <meta name="theme-color" content="#02050a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260530" />
    <link rel="alternate icon" href="/favicon.ico?v=20260530" />
    <title>Applied AI Solutions | Local AI Systems for Real Work</title>
  </head>
  <body class="cinema-page">
    <header class="site-header">
      <nav class="nav shell" aria-label="Main navigation">
        <a class="brand" href="/">
          <img src="/assets/logo-system/aas-mountain-aa-v4-summit-mark.svg" alt="Applied AI Solutions" width="512" height="512" />
          <span>
            <strong>Applied AI</strong>
            <small>Solutions</small>
          </span>
        </a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/beacon/">Beacon</a>
          <a href="/projects/">Projects</a>
          <a href="/pricing/">Pricing</a>
          <a href="#services">Services</a>
          <a class="nav-cta" href="#contact">Contact</a>
        </div>
      </nav>
    </header>

    <main class="cinema-main">
      <div class="cinema-stage" aria-hidden="true">
        <canvas class="cinema-webgl" data-cinema-scene></canvas>
        <img class="stage-image stage-image-roots" src="/assets/retrowave/southern-roots-origin.jpg" alt="" width="763" height="250" />
        <img class="stage-image stage-image-system" src="/assets/retrowave/retrowave-system-banner.jpg" alt="" width="1500" height="500" />
        <img class="stage-image stage-image-mark" src="/assets/logo-system/aas-mountain-aa-v4-summit-mark.svg" alt="" width="512" height="512" />
        <div class="ridge-map">
          <i></i>
          <i></i>
          <i></i>
        </div>
        <div class="stage-readout" aria-hidden="true">
          <span>origin signal</span>
          <strong data-scene-state>roots</strong>
        </div>
        <div class="stage-grid"></div>
        <div class="stage-scan"></div>
      </div>

      <nav class="chapter-rail" aria-label="Page chapters">
        <a href="#top">00</a>
        <a href="#roots">01</a>
        <a href="#systems">02</a>
        <a href="#beacon">03</a>
        <a href="#contact">04</a>
      </nav>

      <section id="top" class="cinema-hero cinema-panel" data-stage="roots">
        <div class="shell cinema-copy hero-copy">
          <p class="cinema-kicker">Applied AI Solutions / Southern roots / 22nd-century systems</p>
          <h1>
            Built from
            <span>home ground</span>
            for the future.
          </h1>
          <p class="cinema-lead">
            Not another AI site wearing the same grid and font. This is the working edge:
            local memory, human approval, machine-scale execution, and roots deep enough
            to keep the whole thing accountable.
          </p>
          <div class="origin-caption" aria-label="Image provenance">
            <span>Base image</span>
            <strong>Southern roots, future-facing systems</strong>
          </div>
          <a class="scroll-cue" href="#roots">Enter the ridge</a>
        </div>
      </section>

      <section id="roots" class="cinema-panel cinema-chapter" data-stage="roots">
        <div class="shell cinema-chapter-grid">
          <div class="chapter-meta">
            <span>//01 Roots</span>
            <a href="#top">Back to top</a>
          </div>
          <div class="cinema-copy chapter-copy">
            <h2>
              Southern born.
              <span>Systems raised.</span>
            </h2>
            <p>
              The place matters. The work is not abstract, and neither is trust.
              Applied AI Solutions starts with the grounded parts of business:
              reputation, judgment, family pressure, payroll, messy handoffs, and
              the kind of decisions people still have to own after the model answers.
            </p>
            <div class="terrain-proof" aria-label="Operating principles">
              <span>Local first</span>
              <span>Approval aware</span>
              <span>Memory with custody</span>
              <span>Automation that can be audited</span>
            </div>
            <a class="read-link" href="#systems">Read more</a>
          </div>
        </div>
      </section>

      <section id="systems" class="cinema-panel cinema-chapter" data-stage="system">
        <div class="shell cinema-chapter-grid">
          <div class="chapter-meta">
            <span>//02 Systems</span>
            <a href="#top">Back to top</a>
          </div>
          <div class="cinema-copy chapter-copy">
            <h2>
              The consulting
              <span>becomes software.</span>
            </h2>
            <p>
              We do not stop at strategy slides. We map the work, capture the
              knowledge, draw the approval line, and build the operating surface:
              agents, private retrieval, workflow routes, dashboards, training, and
              the tests that prove the system is safe enough to keep.
            </p>
            <div class="system-phrases" aria-label="Service lanes">
              <span data-verb="map">Map</span>
              <span data-verb="remember">Remember</span>
              <span data-verb="route">Route</span>
              <span data-verb="approve">Approve</span>
              <span data-verb="operate">Operate</span>
            </div>
          </div>
        </div>
      </section>

      <section id="beacon" class="cinema-panel cinema-chapter" data-stage="beacon">
        <div class="shell cinema-chapter-grid">
          <div class="chapter-meta">
            <span>//03 Beacon</span>
            <a href="/beacon/">Explore Beacon</a>
          </div>
          <div class="cinema-copy chapter-copy">
            <h2>
              The lab has
              <span>a pulse.</span>
            </h2>
            <p>
              Applied AI Solutions Beacon and LightHouseOS are the product layer under
              the public promise: voice, memory, goals, tools, approval gates,
              desktop presence, and a local-first operating layer that can grow
              without handing the keys to someone else's cloud.
            </p>
            <div class="name-stack cinema-name-stack" aria-label="Product names">
              <a href="/beacon/"><strong>Beacon Voice</strong><span>live collaboration</span></a>
              <a href="/beacon/"><strong>Beacon Desk</strong><span>desktop presence</span></a>
              <a href="/projects/"><strong>LightHouseOS</strong><span>local-first agent layer</span></a>
              <a href="/projects/"><strong>Applied operators</strong><span>implementation and verification</span></a>
            </div>
          </div>
        </div>
      </section>

      <section id="contact" class="cinema-panel cinema-chapter cinema-final" data-stage="mark">
        <div class="shell cinema-copy final-copy">
          <IntakeForm
            eyebrow="//04 Start"
            title="Bring the work"
            titleAccent="that still bites."
            body="The documents. The handoffs. The approvals. The place where everybody knows the current way is leaking time, but nobody trusts a black box enough to fix it. We start there."
            intent="AI Workflow Consultation"
            source="home"
          />
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="shell footer-inner">
        <span>┬⌐ {year} Applied AI Solutions</span>
        <nav aria-label="Footer navigation">
          <a href="/beacon/">Beacon</a>
          <a href="/projects/">Projects</a>
          <a href="https://github.com/Applied-AI-Solutions-hub/aas">GitHub</a>
          <a href="mailto:info@appliedai.solutions">info@appliedai.solutions</a>
        </nav>
      </div>
    </footer>
    <script>
      import "../scripts/site-motion.js";
    </script>
  </body>
</html>