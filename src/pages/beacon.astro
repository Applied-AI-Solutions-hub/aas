---
import "../styles/global.css";

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Beacon is the Applied AI Solutions companion surface for LightHouseOS: Beacon Voice, Beacon Desk, local memory, visible approvals, and OpenClaw-powered tools."
    />
    <meta name="theme-color" content="#02050a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260530" />
    <link rel="alternate icon" href="/favicon.ico?v=20260530" />
    <title>Beacon | Voice and Desktop Companion for LightHouseOS</title>
  </head>
  <body class="cinema-page cinema-page-beacon">
    <header class="site-header">
      <nav class="nav shell" aria-label="Beacon navigation">
        <a class="brand" href="/">
          <img src="/assets/retrowave/beacon-retrowave-mark.png" alt="Beacon" width="1024" height="1024" />
          <span>
            <strong>Beacon</strong>
            <small>by Applied AI</small>
          </span>
        </a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/projects/">Projects</a>
          <a href="#surfaces">Surfaces</a>
          <a href="/#services">Services</a>
          <a class="nav-cta" href="mailto:info@appliedai.solutions?subject=Beacon%20Product%20Inquiry">Contact</a>
        </div>
      </nav>
    </header>

    <main class="cinema-main">
      <div class="cinema-stage" aria-hidden="true">
        <canvas class="cinema-webgl" data-cinema-scene></canvas>
        <img class="stage-image stage-image-roots" src="/assets/retrowave/beacon-retrowave-banner.jpg" alt="" width="1500" height="500" />
        <img class="stage-image stage-image-system" src="/assets/retrowave/beacon-retrowave-reveal-loop-poster.jpg" alt="" width="1500" height="844" />
        <img class="stage-image stage-image-mark" src="/assets/retrowave/beacon-retrowave-mark.png" alt="" width="1024" height="1024" />
        <div class="ridge-map">
          <i></i>
          <i></i>
          <i></i>
        </div>
        <div class="stage-readout" aria-hidden="true">
          <span>companion signal</span>
          <strong data-scene-state>beacon</strong>
        </div>
        <div class="stage-grid"></div>
        <div class="stage-scan"></div>
      </div>

      <nav class="chapter-rail" aria-label="Page chapters">
        <a href="#top">00</a>
        <a href="#surfaces">01</a>
        <a href="#boundaries">02</a>
        <a href="#path">03</a>
        <a href="#contact">04</a>
      </nav>

      <section id="top" class="cinema-hero cinema-panel" data-stage="beacon">
        <div class="shell cinema-copy hero-copy">
          <p class="cinema-kicker">Beacon / Voice / Desk / LightHouseOS</p>
          <h1>
            A companion
            <span>with boundaries.</span>
          </h1>
          <p class="cinema-lead">
            Beacon is the human-facing product surface for LightHouseOS. It brings live
            collaboration, durable memory, routed tools, and approval-aware action into one
            recognizable companion experience.
          </p>
          <div class="origin-caption" aria-label="Beacon status">
            <span>Current lane</span>
            <strong>Voice first, desktop next, local system underneath</strong>
          </div>
          <a class="scroll-cue" href="#surfaces">Enter Beacon</a>
        </div>
      </section>

      <section id="surfaces" class="cinema-panel cinema-chapter" data-stage="beacon">
        <div class="shell cinema-chapter-grid">
          <div class="chapter-meta">
            <span>//01 Surfaces</span>
            <a href="#top">Back to top</a>
          </div>
          <div class="cinema-copy chapter-copy">
            <h2>
              Not one
              <span>chat window.</span>
            </h2>
            <p>
              Beacon is the front door to a governed local system. Voice handles live
              collaboration, Desk gives the system presence on the machine, and LightHouseOS
              carries the local-first layer underneath.
            </p>
            <div class="cinema-name-stack surface-stack" aria-label="Beacon product surfaces">
              <a href="#surfaces"><strong>Beacon Voice</strong><span>live working-room collaboration</span></a>
              <a href="#surfaces"><strong>Beacon Desk</strong><span>desktop-native presence</span></a>
              <a href="/projects/"><strong>LightHouseOS</strong><span>agents, goals, memory, tools</span></a>
              <a href="/projects/"><strong>ARC</strong><span>implementation backbone</span></a>
            </div>
          </div>
        </div>
      </section>

      <section id="boundaries" class="cinema-panel cinema-chapter" data-stage="system">
        <div class="shell cinema-chapter-grid">
          <div class="chapter-meta">
            <span>//02 Boundaries</span>
            <a href="/projects/">Build proof</a>
          </div>
          <div class="cinema-copy chapter-copy">
            <h2>
              Useful does not
              <span>mean uncontrolled.</span>
            </h2>
            <p>
              Beacon is designed around explicit permissions. It can help with memory,
              workflow reasoning, tool routing, and draft preparation, while external
              actions stay visible and approved by the human owner.
            </p>
            <div class="terrain-proof" aria-label="Trust boundaries">
              <span>Private by default</span>
              <span>Approval before action</span>
              <span>Routed execution</span>
              <span>No pretending at tools</span>
            </div>
          </div>
        </div>
      </section>

      <section id="path" class="cinema-panel cinema-chapter" data-stage="roots">
        <div class="shell cinema-chapter-grid">
          <div class="chapter-meta">
            <span>//03 Build Path</span>
            <a href="/projects/">See projects</a>
          </div>
          <div class="cinema-copy chapter-copy">
            <h2>
              From one machine
              <span>to a product.</span>
            </h2>
            <p>
              Beacon starts where the work is already happening: Adam's workspace, Discord,
              the desktop shell, local memory, and OpenClaw. The product path is to keep the
              same companion backbone while making each surface polished enough for real users.
            </p>
            <div class="cinema-step-line" aria-label="Beacon build path">
              <span><strong>Now</strong> Voice and ARC working together</span>
              <span><strong>Next</strong> Beacon Desk as a polished shell</span>
              <span><strong>Later</strong> LightHouseOS as an installable layer</span>
            </div>
          </div>
        </div>
      </section>

      <section id="contact" class="cinema-panel cinema-chapter cinema-final" data-stage="mark">
        <div class="shell cinema-copy final-copy">
          <p class="cinema-kicker">//04 Demo</p>
          <h2>
            Start with the
            <span>workflow that needs a companion.</span>
          </h2>
          <p>
            Intake, memory, reports, approvals, follow-up, voice collaboration, or a desktop
            surface that keeps the work visible without giving away control.
          </p>
          <a class="button primary" href="mailto:info@appliedai.solutions?subject=Beacon%20Product%20Inquiry">Contact Applied AI Solutions</a>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="shell footer-inner">
        <span>© {year} Applied AI Solutions</span>
        <nav aria-label="Footer navigation">
          <a href="/">Applied AI Solutions</a>
          <a href="/projects/">Projects</a>
          <a href="mailto:info@appliedai.solutions">info@appliedai.solutions</a>
        </nav>
      </div>
    </footer>
    <script>
      import "../scripts/site-motion.js";
    </script>
  </body>
</html>
