---
import "../styles/global.css";

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Beacon is the Applied AI Solutions companion surface for LightHouseOS: Beacon Voice, Beacon Desk, local memory, visible approvals, and OpenClaw-powered tools."
    />
    <meta name="theme-color" content="#02050a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260530" />
    <link rel="alternate icon" href="/favicon.ico?v=20260530" />
    <title>Beacon | Voice and Desktop Companion for LightHouseOS</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav shell" aria-label="Beacon navigation">
        <a class="brand" href="/">
          <img src="/assets/retrowave/beacon-retrowave-mark.png" alt="Beacon" width="1024" height="1024" />
          <span>
            <strong>Beacon</strong>
            <small>by Applied AI</small>
          </span>
        </a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/projects/">Projects</a>
          <a href="#surfaces">Surfaces</a>
          <a href="/#services">Services</a>
          <a class="nav-cta" href="mailto:info@appliedai.solutions?subject=Beacon%20Product%20Inquiry">Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <section class="hero hero-beacon">
        <div class="hero-art" aria-hidden="true">
          <img src="/assets/retrowave/beacon-retrowave-banner.jpg" alt="" width="1500" height="500" />
          <div class="motion-field">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
        <div class="shell hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">Beacon companion system</p>
            <h1>A local AI companion with a voice, a desktop presence, and visible boundaries.</h1>
            <p class="lead">
              Beacon is the human-facing product surface for LightHouseOS. It brings live
              collaboration, durable memory, routed tools, and approval-aware action into one
              recognizable companion experience.
            </p>
            <div class="action-row">
              <a class="button primary" href="#surfaces">View surfaces</a>
              <a class="button secondary" href="/projects/">See the build proof</a>
            </div>
            <a class="scroll-cue" href="#surfaces">Scroll to discover more</a>
          </div>

          <aside class="beacon-hero-media" aria-label="Beacon companion preview">
            <video
              src="/assets/retrowave/beacon-retrowave-reveal-loop.mp4"
              poster="/assets/retrowave/beacon-retrowave-reveal-loop-poster.jpg"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            ></video>
            <div class="beacon-media-caption">
              <span class="status-dot"></span>
              <strong>Beacon Voice</strong>
              <span>live collaboration</span>
            </div>
            <div class="beacon-surface-pills" aria-label="Beacon product surfaces">
              <span>Voice</span>
              <span>Desk</span>
              <span>LightHouseOS</span>
            </div>
          </aside>
        </div>
      </section>

      <section class="route-dock" aria-label="Beacon routes">
        <div class="shell route-grid route-grid-three">
          <a class="route-card" href="/">
            <span>AAS</span>
            <strong>Consulting Home</strong>
            <small>The business workflow and implementation front door.</small>
          </a>
          <a class="route-card featured-route" href="#surfaces">
            <span>Beacon</span>
            <strong>Product Surfaces</strong>
            <small>Voice, Desk, and LightHouseOS in one companion system.</small>
          </a>
          <a class="route-card" href="/projects/">
            <span>Proof</span>
            <strong>Build Lanes</strong>
            <small>The work behind ARC, OpenClaw, and local-first operations.</small>
          </a>
        </div>
      </section>

      <section id="surfaces" class="section">
        <div class="shell section-grid">
          <div class="section-copy-block">
            <p class="eyebrow">Product surfaces</p>
            <h2>Beacon is not one chat window. It is the front door to a governed local system.</h2>
            <p>
              The names matter because the surfaces do different jobs: Beacon Voice handles live
              collaboration, Beacon Desk gives the local system a desktop presence, and LightHouseOS
              is the operating layer underneath.
            </p>
          </div>
          <div class="tile-grid tile-grid-three">
            <article>
              <span>Voice</span>
              <h3>Beacon Voice</h3>
              <p>Live working-room collaboration with short answers, routed tool work, and approval gates.</p>
            </article>
            <article>
              <span>Desk</span>
              <h3>Beacon Desk</h3>
              <p>A Windows companion shell for local status, quick questions, and desktop-native presence.</p>
            </article>
            <article>
              <span>Core</span>
              <h3>LightHouseOS</h3>
              <p>The local-first layer for agents, goals, memory, tools, voice, and human approval policy.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section section-contrast">
        <div class="shell product-grid product-grid-reverse">
          <div>
            <p class="eyebrow">Trust boundary</p>
            <h2>Useful does not mean uncontrolled.</h2>
            <p>
              Beacon is designed around explicit permissions. It can help with memory, workflow
              reasoning, tool routing, and draft preparation, but external actions stay visible and
              approved by the human owner.
            </p>
            <dl class="signal-list compact">
              <div>
                <dt>Private by default</dt>
                <dd>Local context and workspace memory stay in the local-first operating model.</dd>
              </div>
              <div>
                <dt>Approval before action</dt>
                <dd>Email, social, account, spending, and customer-facing changes require sign-off.</dd>
              </div>
              <div>
                <dt>Routed execution</dt>
                <dd>Beacon can hand work to ARC, OpenClaw tools, or documented workflows instead of pretending.</dd>
              </div>
            </dl>
          </div>
          <div class="media-frame media-frame-current">
            <img src="/assets/retrowave/beacon-retrowave-banner.jpg" alt="Beacon retrowave identity banner" width="1500" height="500" />
          </div>
        </div>
      </section>

      <section class="section">
        <div class="shell proof-band">
          <div>
            <p class="eyebrow">Build path</p>
            <h2>From Adam's machine to customer-ready product surfaces.</h2>
          </div>
          <div class="proof-list">
            <article>
              <strong>Now</strong>
              <p>Beacon Voice and ARC work together through OpenClaw, skills, memory, and clear approval rules.</p>
            </article>
            <article>
              <strong>Next</strong>
              <p>Beacon Desk becomes a polished Windows companion with Fluent-style density and local status.</p>
            </article>
            <article>
              <strong>Later</strong>
              <p>LightHouseOS becomes an installable local AI operating layer for business workflows.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section final-cta">
        <div class="shell cta-band">
          <div>
            <p class="eyebrow">Beacon demos</p>
            <h2>Talk about a companion surface for your workflow.</h2>
            <p>Start with one real process: intake, context, approvals, memory, reports, or follow-up.</p>
          </div>
          <a class="button primary" href="mailto:info@appliedai.solutions?subject=Beacon%20Product%20Inquiry">Contact Applied AI Solutions</a>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="shell footer-inner">
        <span>© {year} Applied AI Solutions</span>
        <nav aria-label="Footer navigation">
          <a href="/">Applied AI Solutions</a>
          <a href="/projects/">Projects</a>
          <a href="mailto:info@appliedai.solutions">info@appliedai.solutions</a>
        </nav>
      </div>
    </footer>
    <script>
      import "../scripts/site-motion.js";
    </script>
  </body>
</html>
