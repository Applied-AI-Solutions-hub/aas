---
import "../styles/global.css";

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Beacon is the Applied AI Solutions companion surface for LightHouseOS: Beacon Voice, Beacon Desk, private memory, visible approvals, and local-first tool use."
    />
    <meta name="theme-color" content="#000000" />
    <title>Beacon | Applied AI Solutions</title>
  </head>
  <body class="beacon-page redesigned-page">
    <div class="cosmic-backdrop" aria-hidden="true"></div>

    <header class="site-header beacon-header">
      <nav class="nav shell" aria-label="Beacon navigation">
        <a class="brand" href="/">
          <img
            class="brand-header-mark"
            src="/assets/aas-logo-current.jpg"
            alt="Applied AI Solutions"
            width="512"
            height="512"
          />
          <span class="brand-lockup">
            <strong>Beacon</strong>
            <span>Alpha Build</span>
          </span>
        </a>
        <div class="nav-links">
          <a href="/">AAS</a>
          <a href="/projects/">Projects</a>
          <a href="#system">System</a>
          <a class="button secondary" href="mailto:info@appliedai.solutions?subject=Beacon%20Alpha%20Build">Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <section class="redesign-hero beacon-product-hero" aria-labelledby="beacon-title">
        <div class="shell beacon-product-grid">
          <div class="redesign-hero-copy beacon-product-copy" data-animate>
            <p class="eyebrow">LightHouseOS product surface</p>
            <h1 id="beacon-title">Beacon turns a local AI operating layer into something you can talk to.</h1>
            <p class="lead">
              Beacon is the companion layer for LightHouseOS: voice for live collaboration, Desk
              for desktop presence, durable memory, visible approvals, and human-safe action gates.
            </p>
            <div class="beacon-signal-row" aria-label="Beacon product signals">
              <span><strong>Beacon Voice</strong> live collaboration</span>
              <span><strong>Beacon Desk</strong> desktop presence</span>
              <span><strong>LightHouseOS</strong> local-first core</span>
            </div>
            <div class="hero-actions">
              <a class="button beacon-nav" href="/projects/">View builds</a>
              <a class="button secondary" href="mailto:info@appliedai.solutions?subject=Beacon%20Alpha%20Build">
                Talk about Beacon
              </a>
            </div>
          </div>

          <div class="beacon-demo-stage" data-animate aria-label="Beacon product preview">
            <video autoplay muted loop playsinline preload="metadata" poster="/assets/beacon-grok-clean-hero-idle-v2-transparent-poster.png">
              <source src="/assets/beacon-aas-product-intro.mp4" type="video/mp4" />
            </video>
            <div class="beacon-demo-topbar">
              <span class="status-dot"></span>
              <strong>Beacon alpha</strong>
              <span>Voice + Desk lane</span>
            </div>
            <div class="beacon-demo-rail" aria-hidden="true">
              <span>Memory</span>
              <span>Approval</span>
              <span>Tools</span>
              <span>Goals</span>
            </div>
          </div>
        </div>
      </section>

      <section id="system" class="section redesigned-section beacon-system-section">
        <div class="shell beacon-system-grid">
          <div class="section-header" data-animate>
            <p class="eyebrow">System direction</p>
            <h2>A voice-and-desktop companion over a governed local system.</h2>
            <p class="section-copy">
              The website explains the work, but the product is Beacon Voice, Beacon Desk, and the
              LightHouseOS core behind them: persistent context, visible state, practical controls,
              and the trust boundaries a real business assistant needs.
            </p>
          </div>
          <aside class="ops-panel beacon-panel" aria-label="Beacon build status" data-animate>
            <div class="ops-panel-header">
              <span class="status-dot"></span>
              <strong>LightHouseOS stack</strong>
            </div>
            <dl>
              <div>
                <dt>Core</dt>
                <dd>OpenClaw runtime, tools, memory, goals, and approval policy.</dd>
              </div>
              <div>
                <dt>Companion</dt>
                <dd>Beacon Voice for conversation and Beacon Desk for desktop presence.</dd>
              </div>
              <div>
                <dt>Boundary</dt>
                <dd>Private by default with explicit gates for external actions.</dd>
              </div>
            </dl>
          </aside>
          <div class="service-list beacon-system-list" data-animate>
            <article>
              <span>01</span>
              <h3>Durable memory</h3>
              <p>Project context, decisions, and lessons survive beyond one chat buffer.</p>
            </article>
            <article>
              <span>02</span>
              <h3>Routed tools</h3>
              <p>Voice can route work to ARC, tools, and goals without pretending every action lives in the voice loop.</p>
            </article>
            <article>
              <span>03</span>
              <h3>Human approvals</h3>
              <p>Public, financial, account, and customer-facing changes require explicit approval.</p>
            </article>
            <article>
              <span>04</span>
              <h3>Product surfaces</h3>
              <p>Beacon Voice and Beacon Desk make the system feel present without turning the marketing site into the product.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section redesigned-section proof-section beacon-proof-section">
        <div class="shell feature-callout beacon-feature" data-animate>
          <div>
            <p class="eyebrow">LightHouseOS path</p>
            <h2>Voice companion now. Desktop presence next. Local operating layer underneath.</h2>
            <p class="section-copy">
              The honest product path starts with Beacon Voice, Beacon Desk, the OpenClaw workspace,
              and durable goal workflows. The long-term target is LightHouseOS: a local AI
              environment a business can own.
            </p>
          </div>
          <ol class="compact-steps">
            <li><span>Now</span> Beacon Voice with ARC-routed tool work</li>
            <li><span>Next</span> Beacon Desk as the desktop companion</li>
            <li><span>Later</span> LightHouseOS workstation image</li>
          </ol>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="shell">
        <a class="footer-brand" href="/" aria-label="Applied AI Solutions home">
          <img src="/assets/aas-logo-current.jpg" alt="Applied AI Solutions" width="512" height="512" />
        </a>
        <span>© {year}</span>
        <div class="footer-links">
          <a href="/">Applied AI Solutions</a>
          <a href="/projects/">Projects</a>
          <a href="mailto:info@appliedai.solutions">info@appliedai.solutions</a>
        </div>
      </div>
    </footer>

    <script>
      import { animate, inView, stagger } from "motion";

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (!reduceMotion) {
        inView("[data-animate]", (element) => {
          animate(
            element,
            { opacity: [0, 1], transform: ["translateY(18px)", "translateY(0)"] },
            { duration: 0.58, delay: stagger(0.035), easing: [0.22, 1, 0.36, 1] }
          );
        }, { margin: "0px 0px -10% 0px" });
      }
    </script>
  </body>
</html>
