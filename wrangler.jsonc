{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "appliedai-solutions",
  "compatibility_date": "2026-05-25",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash"
  },
  "routes": [
    {
      "pattern": "appliedai.solutions",
      "custom_domain": true
    },
    {
      "pattern": "www.appliedai.solutions",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
