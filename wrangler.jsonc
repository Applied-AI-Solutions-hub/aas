{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "appliedai-solutions",
  "compatibility_date": "2026-05-25",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/client",
    "html_handling": "auto-trailing-slash"
  },
  "observability": {
    "enabled": true
  }
}
